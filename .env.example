# SimpleCRM — env vars reference
#
# Copy to `.env.production` on the deploy host (or set each value in the
# Coolify UI). NEVER commit the filled-in version to git.

# ---- Hosts --------------------------------------------------------------
# Public hostnames that Traefik/Cloudflare will serve.
API_HOST=api.simplecrm.cz
WEB_HOST=app.simplecrm.cz

# Full URL the frontend uses to call the backend.
VITE_API_BASE_URL=https://api.simplecrm.cz

# ---- Landing hero animation (frontend, build-time) ----------------------
# Tunes the marketing hero's "mold-colony" background glows. All optional —
# omit them entirely and the sane defaults below apply. Vite inlines these
# at build time, so changes need a frontend rebuild / dev-server restart.
# (prefers-reduced-motion always disables the animation regardless.)
#
# Global speed multiplier: higher = faster. Divides each blob's base
# duration (22/29/34s), so 2.5 → ~8.8/11.6/13.6s. Default 2.5, range 0.25–10.
VITE_HERO_BLOB_SPEED=2.5
# Morph amplitude: how far each blob's scale departs from 1 (bloom/shrink).
# 1 = original character, 0 = no pulsing, >1 = more dramatic. Default 1, range 0–3.
VITE_HERO_BLOB_ERRATICITY=1
# Travel distance: how far the blobs drift across the hero. 1 = original,
# 0 = stay put, >1 = roam wider. Default 1, range 0–3.
VITE_HERO_BLOB_TRAVEL=1

# ---- Database -----------------------------------------------------------
POSTGRES_USER=simplecrm
POSTGRES_PASSWORD=                    # openssl rand -base64 32
POSTGRES_DB=simplecrm

# ---- JWT ----------------------------------------------------------------
JWT_SECRET=                           # openssl rand -base64 48
# Access-token TTL (minutes) and refresh-token TTL (days).
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30

# ---- Google OAuth -------------------------------------------------------
# Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Redirect URI must match exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.simplecrm.cz/api/v1/auth/google/callback

# Where to send the user after login/logout — both should point at the
# frontend origin.
FRONTEND_SUCCESS_REDIRECT=https://app.simplecrm.cz/app
FRONTEND_LOGIN_REDIRECT=https://app.simplecrm.cz/login

# ---- CORS ---------------------------------------------------------------
# Comma-separated list of allowed origins.
CORS_ORIGINS=https://app.simplecrm.cz

# ---- SMTP (Zoho Mail) ---------------------------------------------------
# Zoho Mail SMTP — EU data center to match Hetzner FSN1 hosting. Port 465
# is implicit-TLS (SSL); switch to 587 + SMTP_USE_STARTTLS=true if your
# Zoho org requires STARTTLS.
#
# The SMTP account holds the credentials; `faktury@` and `info@` are
# Zoho "Send-As" identities on the same account (Zoho Mail Admin →
# Mail Accounts → <user> → Send-As).
#
# When SMTP_HOST is empty the backend logs payloads instead of sending,
# which is the right behavior for local dev.
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false
# Primary Zoho mailbox used for SMTP auth — typically the address that
# owns the Send-As identities below. Set the matching password (or app
# password, if Zoho 2FA is on).
SMTP_USERNAME=your-zoho-mailbox@simplecrm.cz
SMTP_PASSWORD=                        # set to the Zoho account / app password
# Send-As identities. Defaults align with the production setup; override
# in staging to send from non-prod addresses.
SMTP_FROM_INVOICES=faktury@simplecrm.cz
SMTP_FROM_INFO=info@simplecrm.cz
# Where bug reports + improvement suggestions land.
FEEDBACK_RECIPIENT_EMAIL=info@simplecrm.cz

# ---- Observability ------------------------------------------------------
# Optional. Create a project at https://sentry.io EU region.
SENTRY_DSN=

# ---- Backups (used by scripts/backup_postgres.sh) -----------------------
# Hetzner Object Storage is S3-compatible.
BACKUP_S3_ENDPOINT=https://fsn1.your-objectstorage.com
BACKUP_S3_BUCKET=simplecrm-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
# Retention in days; the script prunes older dumps.
BACKUP_RETENTION_DAYS=7
