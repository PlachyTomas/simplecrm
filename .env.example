# SimpleCRM — env vars reference
#
# Copy to `.env.production` on the deploy host (or set each value in the
# Coolify UI). NEVER commit the filled-in version to git.

# ---- Hosts --------------------------------------------------------------
# Public hostnames that Traefik/Cloudflare will serve.
API_HOST=api.simplecrm.cz
WEB_HOST=app.simplecrm.cz

# Full URL the frontend uses to call the backend.
VITE_API_BASE_URL=https://api.simplecrm.cz

# ---- Database -----------------------------------------------------------
POSTGRES_USER=simplecrm
POSTGRES_PASSWORD=                    # openssl rand -base64 32
POSTGRES_DB=simplecrm

# ---- JWT ----------------------------------------------------------------
JWT_SECRET=                           # openssl rand -base64 48
# Access-token TTL (minutes) and refresh-token TTL (days).
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30

# ---- Google OAuth -------------------------------------------------------
# Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Redirect URI must match exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.simplecrm.cz/api/v1/auth/google/callback

# Where to send the user after login/logout — both should point at the
# frontend origin.
FRONTEND_SUCCESS_REDIRECT=https://app.simplecrm.cz/app
FRONTEND_LOGIN_REDIRECT=https://app.simplecrm.cz/login

# ---- CORS ---------------------------------------------------------------
# Comma-separated list of allowed origins.
CORS_ORIGINS=https://app.simplecrm.cz

# ---- Observability ------------------------------------------------------
# Optional. Create a project at https://sentry.io EU region.
SENTRY_DSN=

# ---- Backups (used by scripts/backup_postgres.sh) -----------------------
# Hetzner Object Storage is S3-compatible.
BACKUP_S3_ENDPOINT=https://fsn1.your-objectstorage.com
BACKUP_S3_BUCKET=simplecrm-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
# Retention in days; the script prunes older dumps.
BACKUP_RETENTION_DAYS=7
