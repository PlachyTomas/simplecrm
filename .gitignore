# Docker dev volumes — none of these should be committed
postgres-data/

# Local fallback for InvoiceStorage (commit #4 of INVOICES_TASK.md).
# Tests + dev servers write rendered PDF/ISDOC archives here when S3
# isn't configured. Real production storage is the Hetzner bucket.
backend/var/

# Environment files — secrets never committed
.env
.env.local
.env.*.local
.env.production

# Node / Python caches
node_modules/
.venv/
__pycache__/
*.pyc
.ruff_cache/
.mypy_cache/
.pytest_cache/
.tox/
.pnpm-store/

# Frontend build artifacts
dist/
build/
.vite/
coverage/
*.tsbuildinfo
docs/screenshots/

# Python build artifacts
*.egg-info/
.coverage
htmlcov/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# Claude Code local overrides (per-machine permission allowlists)
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
logs/

# claude-loop runtime artefacts (the wrapper writes its PID + log here)
.claude-loop.pid

# Playwright
playwright-report/
test-results/
misc/
.playwright-mcp/
