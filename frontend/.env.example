# Frontend build-time env vars (Vite exposes only VITE_*-prefixed keys to the
# client and bakes them in at build time — change a value, then restart the dev
# server or rebuild). Copy to .env.local and edit; unset keys use the defaults.

# Backend API base URL.
VITE_API_BASE_URL=http://localhost:8000

# --- Landing hero "living blobs" (all optional; each defaults to the shipped look) ---

# Motion speed multiplier. 1 = default, 2 = twice as fast, 0.5 = half speed.
VITE_HERO_SPEED=1

# How erratic the splashes are: randomises each blob's start position, timing,
# and speed spread per page load. 0 = fixed, reproducible layout; 1 = default
# semi-random; higher = more chaotic and varied.
VITE_HERO_ERRATICITY=1

# Splash opacity multiplier (scales each blob's colour intensity). 1 = default.
VITE_HERO_OPACITY=1

# Number of blobs. 0 disables the effect entirely; capped at 24.
VITE_HERO_COUNT=6

# Blur radius in px (softness of each splash). Lower = crisper, higher = softer.
VITE_HERO_BLUR=44

# Splash size multiplier. 1 = default.
VITE_HERO_SIZE=1
